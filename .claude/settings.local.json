{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(cargo build:*)",
      "Bash(cargo run:*)",
      "Bash(curl -s http://127.0.0.1:3000/world)",
      "Bash(curl -s -X POST -H \"Content-Type: application/json\" -d '{\"name\":\"mq\"}' http://127.0.0.1:3000/)",
      "Bash(kill %1)",
      "Bash(curl -s http://127.0.0.1:3000/hello)",
      "Bash(pkill -f \"mq-http\")"
    ]
  }
}
